      "projects": [
        {
          "paths": ["~/sy-dev"]
        }
      ]
    },
    {
      "host": "192.168.1.209",
      "username": "mendel",
      "projects": [
        {
          "paths": ["/home"]
        },
        {
          "paths": ["/home/mendel"]
        },
        {
          "paths": ["~/Coral"]
